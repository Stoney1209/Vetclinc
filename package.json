{
  "name": "vetclinic",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm --parallel -r build",
    "lint": "pnpm --parallel -r lint",
    "db:migrate": "pnpm --filter @vetclinic/api db:migrate",
    "db:generate": "pnpm --filter @vetclinic/api db:generate",
    "db:push": "pnpm --filter @vetclinic/api db:push",
    "db:studio": "pnpm --filter @vetclinic/api db:studio",
    "db:seed": "pnpm --filter @vetclinic/api db:seed"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prisma": "5.22.0",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@prisma/client": "5.22.0"
  }
}
